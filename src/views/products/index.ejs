<!DOCTYPE html>
<html lang="es">
<head>
  <%- include("../partials/head", { title: "Productos" }) %>
</head>
<body>
  <div class="app-shell">
    <%- include("../partials/sidebar", { user }) %>

    <div class="main-content">
      <%- include("../partials/navbar", { user, csrfToken }) %>

      <main class="page-content">
        <h2>Gestión de Productos</h2>
        <p>Listado de productos registrados.</p>

        <% if (canCreate) { %>
          <div style="margin-bottom: 16px;">
            <a href="/products/create" class="btn btn-primary">Crear producto</a>
          </div>
        <% } %>

        <table>
          <thead>
            <tr>
              <th>ID</th>
              <th>Código</th>
              <th>Nombre</th>
              <th>Descripción</th>
              <th>Cantidad</th>
              <th>Precio</th>
              <% if (canManage) { %>
                <th>Acciones</th>
              <% } %>
            </tr>
          </thead>
          <tbody>
            <% products.forEach(p => { %>
              <tr>
                <td><%= p.id %></td>
                <td><%= p.code %></td>
                <td><%= p.name %></td>
                <td><%= p.description %></td>
                <td><%= p.quantity %></td>
                <td>₡ <%= p.price %></td>

                <% if (canManage) { %>
                  <td style="display:flex; gap:8px;">
                    <a href="/products/<%= p.id %>/edit" class="btn btn-primary">Editar</a>

                    <% if (canDelete) { %>
                      <form method="POST" action="/products/<%= p.id %>/delete" style="display:inline;">
                        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                        <button type="submit" class="btn btn-danger">Eliminar</button>
                      </form>
                    <% } %>
                  </td>
                <% } %>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </main>

      <%- include("../partials/footer") %>
    </div>
  </div>
</body>
</html>