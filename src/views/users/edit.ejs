<!DOCTYPE html>
<html lang="es">
<head>
  <%- include("../partials/head", { title: "Editar Usuario" }) %>
</head>
<body>
  <div class="app-shell">
    <%- include("../partials/sidebar", { user: currentUser }) %>

    <div class="main-content">
      <%- include("../partials/navbar", { user: currentUser, csrfToken }) %>

      <main class="page-content">
        <h2>Editar Usuario</h2>

        <% if (error) { %>
          <div class="alert alert-error"><%= error %></div>
        <% } %>

        <form method="POST" action="/users/<%= editableUser.id %>/edit" class="form">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">

          <div class="form-group">
            <label for="username">Username</label>
            <input type="text" id="username" name="username" value="<%= editableUser.username %>" required>
          </div>

          <div class="form-group">
            <label for="email">Correo</label>
            <input type="email" id="email" name="email" value="<%= editableUser.email %>" required>
          </div>

          <div class="form-group">
            <label for="password">Nueva contraseña (opcional)</label>
            <input type="password" id="password" name="password" minlength="6">
          </div>

          <div class="form-group">
            <label for="roleId">Rol</label>
            <select id="roleId" name="roleId" required>
              <% roles.forEach(role => { %>
                <option value="<%= role.id %>" <%= editableUser.roleId === role.id ? "selected" : "" %>>
                  <%= role.name %>
                </option>
              <% }) %>
            </select>
          </div>

          <button type="submit" class="btn btn-primary">Guardar cambios</button>
        </form>
      </main>

      <%- include("../partials/footer") %>
    </div>
  </div>
</body>
</html>