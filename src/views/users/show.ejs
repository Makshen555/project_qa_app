<!DOCTYPE html>
<html lang="es">
<head>
  <%- include("../partials/head", { title: "Detalle Usuario" }) %>
</head>
<body>
  <div class="app-shell">
    <%- include("../partials/sidebar", { user }) %>

    <div class="main-content">
      <%- include("../partials/navbar", { user, csrfToken }) %>

      <main class="page-content">
        <h2>Detalle del Usuario</h2>

        <div class="card">
          <p><strong>ID:</strong> <%= targetUser.id %></p>
          <p><strong>Username:</strong> <%= targetUser.username %></p>
          <p><strong>Email:</strong> <%= targetUser.email %></p>
          <p><strong>Rol:</strong> <%= targetUser.role.name %></p>
          <p><strong>Último login:</strong>
            <%= targetUser.lastLogin ? new Date(targetUser.lastLogin).toLocaleString() : "Nunca" %>
          </p>
        </div>

        <div style="margin-top: 20px;">
          <a href="/users" class="btn btn-primary">Volver</a>

          <% if (user.role === "SUPERADMIN") { %>
            <a href="/users/<%= targetUser.id %>/edit" class="btn btn-primary">
              Editar
            </a>
          <% } %>
        </div>
      </main>

      <%- include("../partials/footer") %>
    </div>
  </div>
</body>
</html>